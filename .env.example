# Database
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=
PGSSLMODE=prefer

# Data source: fake or real
FLOWCASE_DATA_SOURCE=fake

# Flowcase API (only required when FLOWCASE_DATA_SOURCE=real)
FLOWCASE_SUBDOMAIN=
FLOWCASE_API_TOKEN=
FLOWCASE_OFFICE_IDS=
FLOWCASE_LANG_PARAMS=
